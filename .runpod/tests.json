{
  "tests": [
    {
      "name": "tts_voice_clone",
      "input": {
        "text": "Hello, this is a test of the Qwen 3 TTS system. It should sound natural and clear.",
        "language": "English",
        "mode": "voice_clone",
        "voicemap": "mila",
        "speaker": "",
        "instruct": "",
        "ref_url": "",
        "ref_text": ""
      },
      "timeout": 300000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA A40",
    "gpuCount": 1,
    "env": [
      {
        "key": "VOICE_MAP_URL",
        "value": "https://raw.githubusercontent.com/earetaurus/qwen3-tts-runpod/main/voicemap/voicemap.json"
      }
    ],
    "allowedCudaVersions": ["12.7", "12.6"]
  }
}
