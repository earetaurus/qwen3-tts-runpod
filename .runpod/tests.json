{
  "tests": [
    {
      "name": "openai_compatible_tts",
      "input": {
        "path": "/v1/audio/speech",
        "method": "POST",
        "headers": {
          "content-type": "application/json"
        },
        "body": {
          "model": "qwen3-tts",
          "input": "Hello world!",
          "voice": "voice_one",
          "response_format": "mp3",
          "speed": 1.0
        }
      },
      "timeout": 300000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA A40",
    "gpuCount": 1,
    "env": [
      {
        "key": "FORCE_RUNPOD_TEST",
        "value": "1"
      }
    ],
    "allowedCudaVersions": ["12.6", "12.7", "12.8"]
  }
}
